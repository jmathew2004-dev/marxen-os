# Marxen ERP - Environment Configuration Template
# Copy this file to .env and update with your values

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/marxen
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=marxen
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
NODE_ENV=development
PORT=5000

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# ============================================================================
# AI INTEGRATION (Claude API)
# ============================================================================
CLAUDE_API_KEY=your-anthropic-api-key-here

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:5000/api
VITE_ENABLE_VOICE=true

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
ALLOWED_ORIGINS=http://localhost:5173
BODY_LIMIT=200kb
TRUST_PROXY=false
ALLOW_TUNNEL_ORIGINS=true
GLOBAL_RATE_LIMIT_WINDOW_MS=900000
GLOBAL_RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=10
AI_RATE_LIMIT_MAX=30
ENFORCE_SECURE_CONFIG=false

# Production example:
# FRONTEND_URL=https://osmarxen.com
# ALLOWED_ORIGINS=https://osmarxen.com,https://www.osmarxen.com
# TRUST_PROXY=1
# ALLOW_TUNNEL_ORIGINS=false
# ENFORCE_SECURE_CONFIG=true

# ============================================================================
# OPTIONAL: Email Configuration (Future Use)
# ============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=noreply@marxen.com

# ============================================================================
# OPTIONAL: Monitoring & Logging
# ============================================================================
# SENTRY_DSN=your-sentry-dsn
# LOG_LEVEL=info
